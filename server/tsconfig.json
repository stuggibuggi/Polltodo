{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "../dist-server",
    "noEmit": false,
    "noEmitOnError": false,
    "noCheck": true,
    "sourceMap": false,
    "declaration": false,
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": ["src"]
}
