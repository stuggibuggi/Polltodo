DATABASE_URL="postgresql://postgres:password@localhost:5432/Polltodo?schema=public"
JWT_SECRET="change-me"
CORS_ORIGIN="http://localhost:5173"
CLIENT_PUBLIC_BASE_URL="http://localhost:5173"
PORT=4000
CLIENT_HTTPS_ENABLED="false"
CLIENT_HTTPS_PORT="5173"
CLIENT_SSL_CERT_PATH=""
CLIENT_SSL_KEY_PATH=""
CLIENT_SSL_KEY_PASSPHRASE=""
CLIENT_HTTP_REDIRECT_ENABLED="false"
CLIENT_HTTP_PORT="80"
AUTH_MODE="local"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"
LDAP_ENABLED="false"
LDAP_URL="ldap://your-ad-server:389"
LDAP_DOMAIN="your-domain"
LDAP_SEARCH_BASE="dc=example,dc=local"
LDAP_SEARCH_FILTER="(sAMAccountName={{username}})"
LDAP_EMAIL_ATTR="mail"
LDAP_NAME_ATTR="cn"
LDAP_ALLOW_UPN="false"
LDAP_GROUP_ATTR="memberOf"
LDAP_ROLE_MAP="AD-Admins:ADMIN,AD-Editors:EDITOR,AD-Viewers:VIEWER"
LDAP_DEBUG="false"
LDAP_TIMEOUT_MS="8000"
JIRA_ISSUE_CREATE_URL="https://issues.example.com/jira/rest/api/2/issue/"
JIRA_ISSUE_BROWSE_URL="https://issues.example.com/jira/browse/"
JIRA_USER_SEARCH_URL="https://issues.example.com/jira/rest/api/2/user/search?username="
JIRA_BASIC_AUTH="Basic <base64-user-colon-password>"
JIRA_DEFAULT_PROJECT_KEY=""
JIRA_DEFAULT_ISSUE_TYPE="Task"
JIRA_CONTACT_CUSTOM_FIELD_ID=""
JIRA_EPIC_NAME_CUSTOM_FIELD_ID=""
JIRA_DEFAULT_COMPONENTS=""
EXTERNAL_IMPORT_SCHEDULER_ENABLED="true"
EXTERNAL_IMPORT_SCHEDULER_TICK_MS="60000"
EXTERNAL_IMPORT_PRISMA_TIMEOUT_MS="120000"
