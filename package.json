{
  "name": "polltodo",
  "version": "1.0.0",
  "description": "Full-stack survey and questionnaire management platform with object-based task scheduling, RBAC, LDAP and Jira integration",
  "author": "Marc Stoffner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stuggibuggi/Polltodo.git"
  },
  "homepage": "https://github.com/stuggibuggi/Polltodo#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json && node -e \"require('fs').mkdirSync('dist-server',{recursive:true}); require('fs').writeFileSync('dist-server/package.json', JSON.stringify({type:'commonjs'}, null, 2));\"",
    "build:prod": "npm run prisma:generate && npm run build:client && npm run build:server",
    "check:contrast": "node scripts/contrast-check.mjs",
    "preview": "vite preview",
    "start:client": "vite preview --host 0.0.0.0 --port 5173",
    "start:server": "node dist-server/index.js",
    "dev:server": "tsx server/src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx server/src/seed.ts",
    "create-admin": "tsx server/src/createAdmin.ts",
    "cron:tasks": "tsx server/src/cron.ts",
    "maintenance:override-cleanup:dry": "tsx server/src/cleanupOverridePolicies.ts --dry-run",
    "maintenance:override-cleanup": "tsx server/src/cleanupOverridePolicies.ts --apply"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "prisma": "5.20.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@prisma/client": "5.20.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "ldapts": "^4.2.5",
    "mssql": "^12.2.0",
    "pm2": "^6.0.14",
    "pm2-windows-service": "^0.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.4.0",
    "tslib": "^2.6.3",
    "xlsx": "^0.18.5"
  }
}
